# ID чата и канала, куда выдается доступ (бот должен быть админом):
COURSE_CHAT_ID=-1001234567890
COURSE_CHANNEL_ID=-1009876543210

# Админы, которым приходит уведомление "Я оплатила":
ADMIN_IDS=123456789

# Фото (URL или file_id Telegram):
WELCOME_PHOTO_URL=https://disk.yandex.ru/i/ekLrZ4k5qdWVsQ
PROMO_PHOTO_URLS=https://disk.yandex.ru/i/ekLrZ4k5qdWVsQ

# Стоимость пакета:
